#!/bin/bash
# Usage: view-circuit <diagram.json> [source-file]
# Opens the interactive circuit viewer with files pre-loaded.
#
# Examples:
#   ./shared/tools/view-circuit projects/101/lab1-led-pot/diagram.json projects/101/lab1-led-pot/src/main.cpp
#   ./shared/tools/view-circuit projects/101/lab3-dc-motor/diagram.json

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
VIEWER="$SCRIPT_DIR/diagram-viewer.html"

if [[ $# -lt 1 ]]; then
  echo "Usage: view-circuit <diagram.json> [source-file]"
  echo ""
  echo "Examples:"
  echo "  view-circuit projects/101/lab1-led-pot/diagram.json"
  echo "  view-circuit projects/101/lab3-dc-motor/diagram.json projects/101/lab3-dc-motor/src/main.cpp"
  exit 1
fi

DIAGRAM_FILE="$1"
SOURCE_FILE="${2:-}"

if [[ ! -f "$DIAGRAM_FILE" ]]; then
  echo "Error: diagram file not found: $DIAGRAM_FILE"
  exit 1
fi

# Read file contents (validate they're readable)
if [[ ! -r "$DIAGRAM_FILE" ]]; then
  echo "Error: cannot read diagram file: $DIAGRAM_FILE"
  exit 1
fi

SOURCE_NAME=""
if [[ -n "$SOURCE_FILE" ]]; then
  if [[ ! -f "$SOURCE_FILE" ]]; then
    echo "Error: source file not found: $SOURCE_FILE"
    exit 1
  fi
  SOURCE_NAME=$(basename "$SOURCE_FILE")
fi

# Generate a temp HTML that embeds the data and loads the viewer
TMPFILE=$(mktemp /tmp/circuit-viewer-XXXXXX.html)

python3 - "$VIEWER" "$DIAGRAM_FILE" "$SOURCE_FILE" "$SOURCE_NAME" "$TMPFILE" << 'PYEOF'
import sys, json

viewer_path, diagram_path, source_path, source_name, out_path = sys.argv[1:6]

# Read the viewer HTML
with open(viewer_path, 'r') as f:
    viewer_html = f.read()

# Read diagram JSON
with open(diagram_path, 'r') as f:
    diagram_json = f.read()

# Read source (may be empty path)
source_content = ''
if source_path:
    with open(source_path, 'r') as f:
        source_content = f.read()

# Build the preload script
preload_script = f'''<script>
window.__PRELOADED = {{
  diagram: {diagram_json.strip()},
  source: {json.dumps(source_content)},
  sourceName: {json.dumps(source_name)}
}};
</script>'''

# Inject BEFORE the main <script> so data is available when IIFE runs
output = viewer_html.replace('<script>\n// ─', preload_script + '\n<script>\n// ─', 1)

with open(out_path, 'w') as f:
    f.write(output)
PYEOF

# Open in default browser
open "file://${TMPFILE}"

echo "Opened: $(basename "$DIAGRAM_FILE")${SOURCE_FILE:+ + $(basename "$SOURCE_FILE")}"
