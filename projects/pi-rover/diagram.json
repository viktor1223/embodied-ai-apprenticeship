  "connections": [
    ["pi3:GPIO5", "l298_L:IN1", "blue", []],
    ["pi3:GPIO6", "l298_L:IN2", "blue", []],
    ["pi3:GPIO12", "l298_L:ENA", "#2196f3", []],
    ["pi3:GPIO19", "l298_L:IN3", "blue", []],
    ["pi3:GPIO26", "l298_L:IN4", "blue", []],
    ["pi3:GPIO13", "l298_L:ENB", "#2196f3", []],

    ["pi3:GPIO20", "l298_R:IN1", "purple", []],
