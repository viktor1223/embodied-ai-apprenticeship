    { "type": "chip-dc-motor", "id": "motor_fr", "top": -60, "left": 700, "attrs": {} },
    { "type": "chip-dc-motor", "id": "motor_rr", "top": 160, "left": 700, "attrs": {} },
    { "type": "chip-hc-sr04", "id": "sonar", "top": -160, "left": 220, "attrs": {} },
