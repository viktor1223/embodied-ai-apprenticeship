    { "type": "chip-csi-camera", "id": "camera", "top": -200, "left": 240, "attrs": { "label": "IMX708 12MP" } },
    { "type": "chip-usb-microphone", "id": "mic", "top": 300, "left": 530, "attrs": { "label": "USB Mic" } }
