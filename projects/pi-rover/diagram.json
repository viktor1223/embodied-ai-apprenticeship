    ["psu_motor:POS", "l298_R:12V", "red", []],
    ["psu_motor:NEG", "l298_R:GND2", "black", []],

    ["camera:CSI", "pi3:CSI", "#78909c", []],

    ["mic:USB", "pi3:USB1", "#78909c", []]
